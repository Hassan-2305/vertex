# Supabase configuration for Vertex Frontend
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# NOTE: For Supabase Edge Functions, you will also need to configure secrets in your Supabase project:
# - GROQ_API_KEY: Set this in Supabase secrets for the strategy-ai Edge function to work:
#   supabase secrets set GROQ_API_KEY=your-groq-api-key
